<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="YogaCustomerApp.Views.MyClassesPage"
             BackgroundColor="LightSkyBlue">

    <StackLayout Padding="20" Spacing="20">
        <Label Text="Booked Classes"
               FontSize="26"
               FontAttributes="Bold"
               TextColor="Black"
               HorizontalOptions="Center"
               Margin="0,0,0,20" />

        <!-- List of all booked classes -->
        <ListView x:Name="BookedClassesListView"
                  ItemsSource="{Binding BookedClasses}"
                  Margin="0,0,0,20"
                  HasUnevenRows="True">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <StackLayout Padding="15" Margin="0,0,0,10" BackgroundColor="WhiteSmoke" Spacing="10">
                            <!-- Class Type -->
                            <Label Text="{Binding ClassType}" FontSize="Medium" TextColor="Blue" FontAttributes="Bold" />

                            <!-- Teacher Name -->
                            <Label Text="{Binding TeacherName}" FontSize="Small" TextColor="Chocolate" />

                            <!-- Class Date -->
                            <Label Text="{Binding Date}" FontSize="Small" TextColor="Black" />

                            <!-- Class Price -->
                            <Label Text="{Binding Price, StringFormat='{0:C}'}" FontSize="Small" TextColor="Red" FontAttributes="Bold" />

                            <!-- Display Email Address -->
                            <Label Text="{Binding Email}" FontSize="Small" TextColor="Black" />

                            <!-- Cancel Class Button -->
                            <Button Text="Cancel Class"
                                    BackgroundColor="DarkRed"
                                    TextColor="White"
                                    CornerRadius="25"
                                    CommandParameter="{Binding .}"
                                    Clicked="OnCancelClassClicked" />
                        </StackLayout>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Display total booked classes count -->
        <StackLayout Spacing="5">
            <Label Text="Total Classes Booked: "
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="Black"
                   HorizontalOptions="Center" />

            <Label x:Name="TotalBookedClassesLabel" 
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="DarkOrange"
                   HorizontalOptions="Center" />
        </StackLayout>
    </StackLayout>
</ContentPage>

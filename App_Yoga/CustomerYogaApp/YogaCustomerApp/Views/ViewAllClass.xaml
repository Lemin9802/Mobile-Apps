<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="YogaCustomerApp.Views.ViewAllClass"
             BackgroundColor="LightSkyBlue">

    <Grid>
        <ScrollView Padding="20">
            <StackLayout Spacing="25">
                <Label Text="Available Classes"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="Black"
                       HorizontalOptions="Center"
                       Margin="0,0,0,20" />
                <Label Text="Teacher Name"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="Black" />
                <Entry x:Name="TeacherSearchEntry"
                       Placeholder="Enter teacher's name"
                       PlaceholderColor="Black"
                       TextColor="Black"
                       TextChanged="OnTeacherSearchTextChanged"
                       HorizontalOptions="FillAndExpand"
                       Margin="0,0,0,20" />
                <ListView x:Name="TeacherSuggestionsListView"
                          IsVisible="False"
                          ItemsSource="{Binding TeacherSuggestions}"
                          ItemTapped="OnTeacherSuggestionTapped"
                          Margin="0,0,0,20">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextCell Text="{Binding TeacherName}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Label Text="Date"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="Black" />
                <DatePicker x:Name="ClassDatePicker"
                            DateSelected="OnDateSelected"
                            TextColor="Black"
                            HorizontalOptions="FillAndExpand"
                            Margin="0,0,0,20" />
                <CollectionView x:Name="YogaClassList" 
                                ItemsSource="{Binding YogaClasses}"
                                VerticalOptions="FillAndExpand"
                                Margin="0,0,0,20">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <StackLayout Margin="0,0,0,20">
                                <Frame Padding="15" Margin="0,0,0,10" CornerRadius="15" BackgroundColor="WhiteSmoke" HasShadow="True">
                                    <StackLayout Spacing="10">
                                        <Label Text="{Binding ClassType}" FontSize="Large" TextColor="Blue" />
                                        <Label Text="{Binding TeacherName}" FontSize="Medium" TextColor="Chocolate" FontAttributes="Bold" />
                                        <StackLayout Orientation="Horizontal" Spacing="10">
                                            <Label Text="{Binding Date}" FontSize="Small" TextColor="Black" />
                                            <Label Text="{Binding Time}" FontSize="Small" TextColor="Black" />
                                        </StackLayout>
                                        <Label Text="{Binding Price, StringFormat='Price: {0:C}'}" FontSize="Small" TextColor="Red" FontAttributes="Bold" />
                                        <Label Text="{Binding Description}" FontSize="Small" TextColor="Black" LineBreakMode="WordWrap" MaxLines="2" />
                                        <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="20">
                                            <Button Text="View Detail" 
                                                    BackgroundColor="DarkOrange" 
                                                    TextColor="White" 
                                                    CornerRadius="20" 
                                                    Padding="10" 
                                                    HeightRequest="40" 
                                                    HorizontalOptions="Center"
                                                    Margin="0,10,0,0"
                                                    Clicked="OnDetailClicked" />
                                            <Button Text="Add to Cart" 
                                                    BackgroundColor="DarkRed" 
                                                    TextColor="White" 
                                                    CornerRadius="20" 
                                                    Padding="10" 
                                                    HeightRequest="40" 
                                                    HorizontalOptions="Center"
                                                    Margin="0,10,0,0"
                                                    Clicked="OnAddToCartClicked" />
                                        </StackLayout>
                                    </StackLayout>
                                </Frame>
                                <BoxView HeightRequest="1" Color="LightGray" Margin="10,0"/>
                            </StackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </StackLayout>
        </ScrollView>
        <Button x:Name="YourCartButton"
                Text="Your Cart (0)"
                BackgroundColor="DarkRed"  
                TextColor="White"
                CornerRadius="0"
                Padding="15"
                HeightRequest="50"
                HorizontalOptions="FillAndExpand"
                VerticalOptions="End"
                Margin="0,20,0,0"
                Clicked="OnYourCartClicked"/>
    </Grid>
</ContentPage>

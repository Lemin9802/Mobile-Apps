<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.LengthConverterApp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#27B32C</item>
        <item name="colorPrimaryVariant">#026D07</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#82F687</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Background color -->
        <item name="android:colorBackground">#E8F5E9</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#4CAF50</item>
        <!-- Text colors -->
        <item name="android:textColorPrimary">#2E7D32</item>
        <item name="android:textColorSecondary">#66BB6A</item>
    </style>
</resources>